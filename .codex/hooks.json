{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "^(startup|resume)$",
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/chester/work/chedex/.codex/hooks/chedex/chedex-governor.mjs' session-start",
            "timeout": 5,
            "statusMessage": "Chedex governor: restore governed workflow context"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/chester/work/chedex/.codex/hooks/chedex/chedex-governor.mjs' stop",
            "timeout": 5,
            "statusMessage": "Chedex governor: enforce terminal workflow state"
          }
        ]
      }
    ]
  }
}
